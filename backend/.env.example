# Server
PORT=3000
NODE_ENV=production

# JWT — change this to a long random string!
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# OpenVPN container connection (CT-100)
VPN_HOST=10.10.0.1
VPN_SSH_USER=root
VPN_SSH_KEY=/root/.ssh/vpn_key
VPN_EASY_RSA=/etc/openvpn/easy-rsa
VPN_STATUS_LOG=/var/log/openvpn/status.log
VPN_TA_KEY=/etc/openvpn/ta.key

# Panel config
PANEL_HTTPS_PORT=443
